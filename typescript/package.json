{
  "name": "@rail0/integration-tests-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testTimeout=300000"
  },
  "dependencies": {
    "@rail0/sdk": "file:../../rail0-ts",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/node": "^22",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [".ts"],
    "testEnvironment": "node",
    "testMatch": ["**/flows/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
