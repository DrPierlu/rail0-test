#!/usr/bin/env bash
# bin/test ‚Äî run the rail0-cli integration flows with a selection menu.
#
#   bin/test            # interactive menu
#   bin/test <n>        # run flow number <n> from the menu
#   bin/test <pattern>  # run flows whose Go test name matches <pattern>
#   bin/test all        # run every CLI flow
#
# Drives `go test ./flows/` in cli/, loading .env automatically. Requires a
# running gateway + indexer (see README); start them yourself before running.

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

# Friendly label ‚Üí Go test name (index-aligned).
LABELS=(
  "authorize ‚Üí capture (settle)"
  "authorize ‚Üí capture ‚Üí refund"
  "charge"
  "authorize ‚Üí void"
  "partial capture √ó2 ‚Üí refund √ó2 ‚Üí release"
  "charge ‚Üí dispute ‚Üí close dispute"
  "ALL flows"
)
TESTS=(
  "TestAuthorizeCapture$"
  "TestAuthorizeCaptureRefund$"
  "TestCharge$"
  "TestAuthorizeVoid$"
  "TestPartialCaptureRefundRelease$"
  "TestDisputeOpenAndClose$"
  "."
)

GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; BOLD='\033[1m'; RESET='\033[0m'

# Check and print the status of the gateway and indexer the flows depend on.
check_services() {
  echo -e "${BOLD}service status${RESET}"

  local gw="${RAIL0_API_URL:-http://localhost:9292}"
  local health; health=$(curl -s -m3 "$gw/health" 2>/dev/null || true)
  if [[ -n "$health" ]]; then
    local detail; detail=$(printf '%s' "$health" | python3 -c \
      'import sys,json;d=json.load(sys.stdin);print(f"contract v{d.get(\"contract_version\")}, chains={d.get(\"active_chains\")}, db={d.get(\"db\")}")' 2>/dev/null || true)
    echo -e "  gateway  ${GREEN}‚óè up${RESET}    $gw  ${detail:+($detail)}"
  else
    echo -e "  gateway  ${RED}‚óè down${RESET}  $gw"
  fi

  local idx="${RAIL0_INDEXER_GRAPHQL_URL:-http://localhost:8080/v1/graphql}"
  local meta; meta=$(curl -s -m3 -X POST "$idx" \
    -H 'Content-Type: application/json' -H 'x-hasura-admin-secret: testing' \
    -d '{"query":"{ chain_metadata { chain_id latest_processed_block block_height } }"}' 2>/dev/null || true)
  if printf '%s' "$meta" | grep -q latest_processed_block; then
    local prog; prog=$(printf '%s' "$meta" | python3 -c \
      'import sys,json
m=json.load(sys.stdin)["data"]["chain_metadata"]
print(", ".join(f"chain {x[\"chain_id\"]}: block {x[\"latest_processed_block\"]}/{x[\"block_height\"]}" for x in m))' 2>/dev/null || true)
    echo -e "  indexer  ${GREEN}‚óè up${RESET}    $idx  ${prog:+($prog)}"
  else
    echo -e "  indexer  ${RED}‚óè down${RESET}  $idx"
  fi

  if [[ -z "$health" || -z "$meta" ]]; then
    echo -e "${YELLOW}warning: a required service looks down ‚Äî start the gateway and indexer before running flows.${RESET}"
  fi
  echo
}

run_flow() {
  local label="$1" pattern="$2"
  echo -e "\n${BOLD}‚îÅ‚îÅ‚îÅ ${label} ‚îÅ‚îÅ‚îÅ${RESET}"
  case "$pattern" in
    *Release*|.) echo -e "${YELLOW}note: the release flow needs a short authorization window ‚Äî start the gateway with AUTHORIZATION_TTL=30.${RESET}" ;;
  esac
  case "$pattern" in
    *Release*) ;; # release wants short TTL; leave it to the operator
    *)         echo -e "${YELLOW}note: capture/refund need a wide window ‚Äî start the gateway with AUTHORIZATION_TTL=300.${RESET}" ;;
  esac
  ( cd cli && go test ./flows/ -run "$pattern" -v -timeout 600s )
}

# Resolve a selection passed as an argument: a menu number, "all", or a pattern.
resolve_arg() {
  local arg="$1"
  if [[ "$arg" == "all" ]]; then echo "ALL flows|."; return; fi
  if [[ "$arg" =~ ^[0-9]+$ ]] && (( arg >= 1 && arg <= ${#LABELS[@]} )); then
    echo "${LABELS[arg-1]}|${TESTS[arg-1]}"; return
  fi
  # treat as a Go test-name pattern
  echo "pattern: ${arg}|${arg}"
}

check_services

if [[ $# -ge 1 ]]; then
  IFS='|' read -r label pattern <<<"$(resolve_arg "$1")"
  run_flow "$label" "$pattern"
  exit $?
fi

echo -e "${BOLD}rail0 integration flows${RESET}  (gateway + indexer must be running)"
PS3=$'\nSelect a flow to run (number): '
select label in "${LABELS[@]}"; do
  if [[ -n "${label:-}" ]]; then
    run_flow "$label" "${TESTS[REPLY-1]}"
    break
  fi
  echo "invalid selection ‚Äî enter a number from the list"
done
