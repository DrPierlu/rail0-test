# Copy to .env and fill in values before running any suite.
# Source with: set -a && source .env && set +a

# API endpoint used by run.sh (api/go/cli suites). bin/test ignores this and
# resolves the endpoint from its -e/--env selection (development | test |
# staging | production) instead, using built-in defaults you can override per
# environment below (uppercased env name):
#   RAIL0_API_URL_DEVELOPMENT=http://localhost:9292
#   RAIL0_API_URL_STAGING=https://rail0-gateway-staging.fly.dev
#   RAIL0_API_URL_PRODUCTION=https://rail0-api.fly.dev
#   RAIL0_INDEXER_URL_STAGING=https://rail0-indexer-staging.fly.dev
#   RAIL0_INDEXER_URL_PRODUCTION=https://rail0-indexer.fly.dev
RAIL0_API_URL=http://localhost:9292

# Test wallet keys — use dedicated throwaway wallets with small balances.
# Payer (buyer): pays the USDC amount.
BUYER_PRIVATE_KEY=0x...
BUYER_ADDRESS=0x...

# Payee (account/merchant): authorizes, captures, refunds.
ACCOUNT_PRIVATE_KEY=0x...
# Payee wallet address (= address of ACCOUNT_PRIVATE_KEY). Used by the cli suite
# as the payment payee (--to).
PAYEE_ADDRESS=0x...

# Account UUID registered in the API (returned by GET /accounts/:id/payment-methods)
ACCOUNT_ID=019e748b-da9a-7c3f-ba32-50572ffd5388

# Chain used by the test wallets (Arc Testnet = 5042002)
CHAIN_ID=5042002
CHAIN_SLUG=arc-testnet
TOKEN_SYMBOL=USDC

# Authorization TTL in seconds — must match AUTHORIZATION_TTL on the API server.
# Set to 30 so the release flow completes in ~35s instead of waiting 7 days.
# Start the API with: AUTHORIZATION_TTL=30 bundle exec puma -C config/puma.rb
AUTHORIZATION_TTL=30

# Test amount in human-readable decimal form (e.g. "1.00" = 1 USDC).
# The API converts to base units using the token's decimals.
AMOUNT=1.00
